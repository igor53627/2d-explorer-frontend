<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @page_title || "2D Explorer" %></title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/style2.css">
    <link rel="stylesheet" href="/static/css/style2-overrides.css">
    <%= @head_meta || "" %>
    <%= @styles || "" %>
</head>
<body>
    <header class="header">
        <div class="topbar">
            <div class="container topbar-inner">
                <div class="topbar-left">
                    <span class="topbar-badge">2D</span>
                </div>
                <div class="topbar-right">
                    <form class="topbar-search" action="/search" method="get">
                        <span class="topbar-search-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <circle cx="11" cy="11" r="7"></circle>
                                <line x1="20" y1="20" x2="16.65" y2="16.65"></line>
                            </svg>
                        </span>
                        <input type="text" name="q" class="topbar-search-input" placeholder="Search by Address / Txn Hash / Block / Token" aria-label="Search by Address / Txn Hash / Block / Token">
                        <span class="topbar-search-shortcut" aria-hidden="true"><kbd>/</kbd></span>
                    </form>
                    <a class="topbar-icon-btn" href="https://igor53627.github.io/2d-docs/" target="_blank" rel="noopener" aria-label="2D Docs" title="2D Docs">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 5h6a3 3 0 0 1 3 3v11H7a3 3 0 0 0-3 3V5z"></path>
                            <path d="M20 5h-6a3 3 0 0 0-3 3v11h6a3 3 0 0 1 3 3V5z"></path>
                        </svg>
                    </a>
                    <%!-- 2d-fork: Theme toggle / Network selector buttons
                        removed — both were upstream Blockscout placeholders
                        with no handler. Theme toggle was never wired; the
                        network/chain selector doesn't apply (2d is its own
                        chain, no multichain switcher). --%>
                </div>
            </div>
        </div>

        <div class="header-main">
            <div class="container header-top">
                <a href="/" class="logo">
                    <svg class="logo-mark" viewBox="0 0 32 32" aria-hidden="true">
                        <circle cx="16" cy="16" r="16" fill="#1f2a44"></circle>
                        <rect x="8.5" y="9" width="4" height="14" fill="#ffffff"></rect>
                        <rect x="14" y="7" width="4" height="18" fill="#ffffff"></rect>
                        <rect x="19.5" y="11" width="4" height="12" fill="#ffffff"></rect>
                    </svg>
                    <span class="logo-title">2D Explorer</span>
                </a>

                <nav class="nav" aria-label="Primary">
                    <a href="/" class="nav-link <%= assigns[:nav_home] || "" %>">Home</a>

                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-toggle <%= assigns[:nav_blocks] || "" %> <%= assigns[:nav_txs] || "" %>" type="button" aria-haspopup="true" aria-expanded="false">
                            Blockchain
                            <svg class="nav-caret" viewBox="0 0 12 12" aria-hidden="true">
                                <path d="M3 4.5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </button>
                        <div class="nav-menu">
                            <div class="nav-menu-inner">
                                <a href="/txs" class="nav-menu-item">Transactions</a>
                                <a href="/blocks" class="nav-menu-item">View Blocks</a>
                            </div>
                        </div>
                    </div>

                    <%!-- 2d-fork: Tokens / NFTs / More-dropdown nav links
                        removed — none of /tokens, /nft-*, /api-docs exist
                        on 2d, so they'd 404. --%>
                </nav>

                <span class="topbar-badge mobile-badge">2D</span>

                <button class="mobile-menu-btn" type="button" aria-label="Open menu" title="Menu">
                    <svg viewBox="0 0 24 24">
                        <line x1="4" y1="7" x2="20" y2="7"></line>
                        <line x1="4" y1="12" x2="20" y2="12"></line>
                        <line x1="4" y1="17" x2="20" y2="17"></line>
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="container">
            <%= @inner_content %>
        </div>
    </main>

    <footer class="footer">
        <div class="container footer-inner">
            <div class="footer-text">
                2D Explorer
                <span class="footer-divider">·</span>
                <span class="footer-version" title="frontend-ex release">v<%= @app_version %>·<%= @git_sha %><%= if assigns[:backend_version], do: " · backend v#{@backend_version}" %><%= if assigns[:backend_sha], do: "·#{@backend_sha}" %></span>
            </div>
            <div class="footer-links">
                <a href="https://igor53627.github.io/2d-docs/" target="_blank" rel="noopener">Docs</a>
            </div>
        </div>
    </footer>

    <%= @scripts || "" %>
    <script>
    document.querySelectorAll('.copy-btn[data-copy]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            navigator.clipboard.writeText(this.dataset.copy).catch(function(err) {
                console.error('Copy failed:', err);
            });
        });
    });

    // CSV export: any <button data-csv-export="<table selector>"
    // data-csv-filename="…"> exports the targeted table's current page.
    // Cells (th/td) marked with data-csv-skip are omitted.
    function csvCell(s) {
        s = (s || '').replace(/\s+/g, ' ').trim();
        if (/[",\r\n]/.test(s)) return '"' + s.replace(/"/g, '""') + '"';
        return s;
    }
    document.querySelectorAll('button[data-csv-export]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var table = document.querySelector(btn.dataset.csvExport);
            if (!table) return;
            var rows = [];
            var ths = table.querySelectorAll('thead th');
            var keep = [];
            ths.forEach(function(th, i) {
                if (!th.hasAttribute('data-csv-skip')) keep.push(i);
            });
            rows.push(keep.map(function(i) { return csvCell(ths[i].textContent); }));
            table.querySelectorAll('tbody tr').forEach(function(tr) {
                var cells = tr.children;
                rows.push(keep.map(function(i) {
                    return csvCell(cells[i] ? cells[i].textContent : '');
                }));
            });
            var csv = rows.map(function(r) { return r.join(','); }).join('\r\n');
            var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = btn.dataset.csvFilename || 'export.csv';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        });
    });

    // Dropdown menu hover handling
    document.querySelectorAll('.nav-dropdown').forEach(function(dropdown) {
        var menu = dropdown.querySelector('.nav-menu-inner');
        var timeout;
        
        function showMenu() {
            clearTimeout(timeout);
            menu.classList.add('is-open');
        }
        
        function hideMenu(e) {
            var related = e.relatedTarget;
            if (related && dropdown.contains(related)) {
                return;
            }
            menu.classList.remove('is-open');
        }
        
        dropdown.addEventListener('mouseenter', showMenu);
        dropdown.addEventListener('mouseleave', hideMenu);
        
        var menuWrapper = dropdown.querySelector('.nav-menu');
        if (menuWrapper) {
            menuWrapper.addEventListener('mouseenter', showMenu);
        }
    });
    </script>
</body>
</html>
